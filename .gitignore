# Criar .dockerignore
cat > .dockerignore << 'EOF'
# Git
.git
.gitignore
.gitattributes

# Docker
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore

# Dados locais do PostgreSQL
postgres_data/
**/postgres_data

# Node modules
node_modules/
**/node_modules

# Build artifacts
bin/
obj/
out/
build/
dist/
target/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Environment files
.env
.env.local
.env.*.local
*.env

# Terraform
terraform/
*.tfstate
*.tfstate.*
.terraform/

# Outros
*.md
LICENSE
README.md
.editorconfig